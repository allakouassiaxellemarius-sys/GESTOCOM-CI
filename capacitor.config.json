{
  "appId": "com.gestocom.ci",
  "appName": "GESTOCOM CI",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["localhost"]
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#1a73e8",
      "showSpinner": true,
      "spinnerColor": "#ffffff"
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#1a73e8"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "buildOptions": {
      "keystorePath": null,
      "keystoreAlias": null
    }
  },
  "ios": {
    "contentInset": "automatic",
    "scheme": "GESTOCOMCI",
    "backgroundColor": "#1a73e8"
  }
}
