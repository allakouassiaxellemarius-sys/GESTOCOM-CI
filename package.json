{
  "name": "gestocom-ci",
  "productName": "GESTOCOM CI",
  "description": "Logiciel de gestion commerciale conçu pour les entreprises ivoiriennes",
  "author": {
    "name": "LES RETROUVAILLES CEZ LUICI",
    "email": "contact@gestocom.ci"
  },
  "private": true,
  "version": "1.5.1",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electronmon .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux",
    "cap:init": "npx cap init gestocom-ci com.gestocom.ci --web-dir dist",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:build:android": "npx cap sync android && cd android && ./gradlew assembleDebug && ./gradlew bundleRelease",
    "cap:build:ios": "npx cap sync ios",
    "installer:all": "node scripts/build-all.mjs",
    "installer:win": "vite build && electron-builder --win",
    "installer:mac": "vite build && electron-builder --mac",
    "installer:linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.2",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "better-sqlite3": "^12.11.1",
    "chart.js": "^4.5.1",
    "electron-store": "^10.0.0",
    "firebase": "^12.16.0",
    "html5-qrcode": "^2.3.8",
    "jeep-sqlite": "^2.5.9",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.4",
    "postcss": "^8.4.49",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.gestocom.ci",
    "productName": "GESTOCOM CI",
    "copyright": "Copyright © 2026 LES RETROUVAILLES CEZ LUICI",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/gestocom.manifest",
        "to": "gestocom.manifest"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "sign": false,
      "forceCodeSigning": false,
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "LES RETROUVAILLES CEZ LUICI",
      "legalTrademarks": "© 2026 LES RETROUVAILLES CEZ LUICI"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GESTOCOM CI",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "warningsAsErrors": false,
      "unicode": true,
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GESTOCOM CI",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "pkg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      },
      "backgroundColor": "#1a73e8"
    },
    "pkg": {
      "isRelocatable": false,
      "allowAnywhere": true,
      "allowCurrentUserHome": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Office;Finance",
      "desktop": {
        "Name": "GESTOCOM CI",
        "Comment": "Logiciel de gestion commerciale",
        "StartupNotify": true,
        "Terminal": false
      },
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}-${version}.${ext}"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "rpm": {
      "depends": [
        "gtk3",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "libXtst",
        "xdg-utils",
        "atspi",
        "libuuid",
        "libsecret"
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "gestocom-ci",
      "repo": "gestocom-ci-desktop",
      "releaseType": "release"
    }
  },
  "packageManager": "npm@10.9.2"
}
